# Скопируй в .env и подставь свои значения.

# Postgres (локально — docker-compose; на проде — свой Postgres на VPS)
DATABASE_URL=postgres://kupec:kupec@localhost:5433/kupec

# Секрет для подписи JWT (обязательно сменить на проде)
JWT_SECRET=change-me-in-production

# API
PORT=8787

# Поллер: какие серверы/разделы опрашивать (по умолчанию — все).
# На старте разумно ограничиться, чтобы уложиться в лимит 5/60с.
POLL_SERVERS=RU17
POLL_PATHS=items,vehicles
POLL_INTERVAL_MS=1800000

# Публичный API Majestic (ключ можно переопределить)
# MAJESTIC_KEY=...
